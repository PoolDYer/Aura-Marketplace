# Environment
NODE_ENV=development

# Server
PORT=3000

# Frontend URL
FRONTEND_URL=http://localhost:5173
CORS_ALLOWED_ORIGINS=http://localhost:5173,http://127.0.0.1:5173

# Public Backend URL for Mercado Pago webhooks in production
BACKEND_URL=http://localhost:3000
PUBLIC_API_URL=http://localhost:3000

# Database
DATABASE_URL="postgresql://user:password@hostname:5432/database?sslmode=require"

# Redis cache
UPSTASH_REDIS_REST_URL="https://your-upstash-instance.upstash.io"
UPSTASH_REDIS_REST_TOKEN="your-upstash-rest-token"
CACHE_PREFIX=aura

# Mercado Pago
MERCADOPAGO_PUBLIC_KEY=your-mercadopago-public-key
MERCADOPAGO_ACCESS_TOKEN=your-mercadopago-access-token
MERCADOPAGO_CURRENCY=PEN
MERCADOPAGO_WEBHOOK_SECRET=your-mercadopago-webhook-secret

# Gemini
GEMINI_API_KEY=your-gemini-api-key

# Email
RESEND_API_KEY=your-resend-api-key
EMAIL_FROM="Aura <no-reply@your-domain.com>"

# Neon Auth
NEON_AUTH_BASE_URL=https://ep-red-darkness-acsr0yn8.neonauth.sa-east-1.aws.neon.tech/neondb/auth
NEON_AUTH_JWKS_URL=https://ep-red-darkness-acsr0yn8.neonauth.sa-east-1.aws.neon.tech/neondb/auth/.well-known/jwks.json
NEON_API_KEY=your-neon-api-key
NEON_PROJECT_ID=your-neon-project-id
NEON_BRANCH_ID=your-neon-branch-id
NEON_AUTH_SYNC_REQUIRED=false

# JWT Secrets (change these in production!)
JWT_SECRET=your-jwt-secret-key-change-this-in-production
JWT_REFRESH_SECRET=your-refresh-secret-key-change-this-in-production

# Cloudinary
CLOUDINARY_CLOUD_NAME=your-cloudinary-cloud-name
CLOUDINARY_API_KEY=your-cloudinary-api-key
CLOUDINARY_API_SECRET=your-cloudinary-api-secret
CLOUDINARY_FOLDER=Aura
