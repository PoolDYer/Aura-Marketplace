       ],\n                    \"body-md\": [\n                            \"14px\",\n                            {\n                                    \"lineHeight\": \"20px\",\n                                    \"fontWeight\": \"400\"\n                            }\n                    ],\n                    \"body-sm\": [\n                            \"12px\",\n                            {\n                                    \"lineHeight\": \"16px\",\n                                    \"fontWeight\": \"400\"\n                            }\n                    ],\n                    \"display-xl\": [\n                            \"56px\",\n                            {\n                                    \"lineHeight\": \"64px\",\n                                    \"letterSpacing\": \"-0.02em\",\n                                    \"fontWeight\": \"700\"\n                            }\n                    ],\n                    \"util-mono\": [\n                            \"14px\",\n                            {\n                                    \"lineHeight\": \"20px\",\n                                    \"letterSpacing\": \"0.02em\",\n                                    \"fontWeight\": \"400\"\n                            }\n                    ],\n                    \"body-lg\": [\n                            \"16px\",\n                            {\n                                    \"lineHeight\": \"24px\",\n                                    \"fontWeight\": \"400\"\n                            }\n                    ],\n                    \"headline-md\": [\n                            \"28px\",\n                            {\n                                    \"lineHeight\": \"36px\",\n                                    \"fontWeight\": \"600\"\n                            }\n                    ]\n            }\n    },\n        },\n      }\n    </script>\n<style>\n        /* Custom Animations & Styles */\n        body {\n            background-color: #FAF6F8;\n            -webkit-font-smoothing: antialiased;\n        }\n        \n        .glass-panel {\n            background: rgba(255, 255, 255, 0.7);\n            backdrop-filter: blur(20px);\n            -webkit-backdrop-filter: blur(20px);\n        }\n\n        .onda-viva-ring {\n            position: absolute;\n            inset: -4px;\n            border-radius: 9999px;\n            background: linear-gradient(45deg, #ffb95a, #006b5b);\n            animation: pulse-ring 3s cubic-bezier(0.4, 0, 0.6, 1) infinite;\n            z-index: -1;\n            opacity: 0.6;\n        }\n\n        @keyframes pulse-ring {\n            0%, 100% {\n                transform: scale(1);\n                opacity: 0.6;\n            }\n            50% {\n                transform: scale(1.15);\n                opacity: 0.2;\n            }\n        }\n        \n        .hide-scroll::-webkit-scrollbar {\n            display: none;\n        }\n        .hide-scroll {\n            -ms-overflow-style: none;\n            scrollbar-width: none;\n        }\n    </style>\n</head>\n<body class=\"text-text-catalog flex flex-col min-h-screen\">\n<!-- TopNavBar -->\n<header class=\"bg-surface/80 dark:bg-bg-voice/80 backdrop-blur-md sticky top-0 z-50 border-b border-outline-variant/30 dark:border-border-muted shadow-sm dark:shadow-none w-full\">\n<div class=\"flex justify-between items-center px-base py-sm max-w-7xl mx-auto w-full\">\n<div class=\"flex items-center gap-md\">\n<span class=\"font-display-lg-mobile text-display-lg-mobile md:font-display-lg md:text-display-lg font-bold text-primary dark:text-primary-fixed-dim tracking-tight\">Aura</span>\n</div>\n<div class=\"hidden md:flex flex-1 max-w-md mx-lg\">\n<div class=\"relative w-full\">\n<input class=\"w-full bg-surface-container-low border-none rounded-full py-2 pl-lg pr-12 font-body-md text-body-md focus:ring-2 focus:ring-primary/50 text-on-surface placeholder:text-text-muted transition-all duration-300\" placeholder=\"¿Qué estás buscando hoy?\" type=\"text\">\n<button class=\"absolute right-3 top-1/2 -translate-y-1/2 text-on-surface-variant hover:text-primary transition-colors\">\n<span class=\"material-symbols-outlined\" data-icon=\"search\">search</span>\n</button>\n</div>\n</div>\n<div class=\"flex items-center gap-sm text-on-surface-variant dark:text-text-muted\">\n<button class=\"p-2 rounded-full hover:bg-surface-variant/50 transition-colors hidden md:block\">\n<span class=\"material-symbols-outlined\" data-icon=\"mic\">mic</span>\n</button>\n<button class=\"p-2 rounded-full hover:bg-surface-variant/50 transition-colors\">\n<span class=\"material-symbols-outlined\" data-icon=\"person\">person</span>\n</button>\n<button class=\"p-2 rounded-full hover:bg-surface-variant/50 transition-colors relative\">\n<span class=\"material-symbols-outlined\" data-icon=\"shopping_cart\">shopping_cart</span>\n<span class=\"absolute top-1 right-1 w-2 h-2 bg-primary rounded-full\"></span>\n</button>\n</div>\n</div>\n</header>\n<!-- Main Content -->\n<main class=\"flex-1 w-full max-w-7xl mx-auto px-base md:px-xl py-lg flex flex-col gap-huge\">\n<!-- Hero Section -->\n<section class=\"flex flex-col items-center justify-center text-center py-huge\">\n<h1 class=\"font-display-lg-mobile text-display-lg-mobile md:font-display-xl md:text-display-xl text-primary max-w-3xl mb-lg\">Encuentra exactamente lo que necesitas, con calma.</h1>\n<p class=\"font-body-lg text-body-lg text-on-surface-variant max-w-2xl mx-auto\">Explora nuestra colección seleccionada de mochilas y accesorios premium. O simplemente toca el botón de voz y dime qué estás buscando.</p>\n</section>\n<!-- Bento Grid Categories -->\n<section class=\"grid grid-cols-1 md:grid-cols-12 gap-lg\">\n<!-- Large Featured Category -->\n<div class=\"md:col-span-8 group cursor-pointer relative overflow-hidden rounded-[24px] bg-surface-catalog shadow-sm border border-outline-variant/10 h-[400px]\">\n<div class=\"absolute inset-0 bg-cover bg-center transition-transform duration-700 group-hover:scale-105\" data-alt=\"A modern lifestyle photograph of a sleek, minimalist premium leather backpack resting on a smooth concrete surface bathed in warm, natural sunlight. The setting implies a high-end urban environment, light-mode aesthetic, with soft shadows and a neutral color palette of soft greys, warm whites, and deep rich browns. The mood is sophisticated, calm, and functional.\" style=\"background-image: url('https://lh3.googleusercontent.com/aida-public/AB6AXuBy4yAlBOpQx68CZg9qteiOgECJl_F6BgwrhNKyDz7uJUh-wot4PpvTcYyrmVRpDAOVUjO7U1EErbRjwHQoF3X2UONjumxAeCgFNs-INESh3fNbUSNYy4svsm9GYeSUsBurPF0cO4TDN6od1A-bB7w2YUHgos-qAgfF0UYriSxoW1Bfqp9PFrGfqRIS80jU-pYOGO_6AusyhDB0Y7Hoy_sr2DaDCptbOARy0gXPJ24ZUEX50ZyTcU1V8g')\"></div>\n<div class=\"absolute inset-0 bg-gradient-to-t from-surface-voice/80 via-transparent to-transparent\"></div>\n<div class=\"absolute bottom-0 left-0 p-lg w-full\">\n<div class=\"glass-panel p-md rounded-xl inline-flex flex-col items-start backdrop-blur-md bg-surface-catalog/80\">\n<h2 class=\"font-headline-md text-headline-md text-primary mb-xs\">Mochilas Urbanas</h2>\n<span class=\"font-body-md text-body-md text-on-surface-variant flex items-center gap-xs\">Explorar Colección <span class=\"material-symbols-outlined text-sm\" data-icon=\"arrow_forward\">arrow_forward</span></span>\n</div>\n</div>\n</div>\n<!-- Smaller Categories -->\n<div class=\"md:col-span-4 flex flex-col gap-lg\">\n<div class=\"flex-1 group cursor-pointer relative overflow-hidden rounded-[24px] bg-surface-catalog shadow-sm border border-outline-variant/10\">\n<div class=\"absolute inset-0 bg-cover bg-center transition-transform duration-700 group-hover:scale-105\" data-alt=\"A close up product shot of a minimalist, modern smart wallet crafted from textured tan leather and brushed aluminum. Resting on a clean white marble table under bright, diffused studio lighting. The aesthetic is clean, light-mode, and tactile, conveying high quality and everyday utility. Soft focus background.\" style=\"background-image: url('https://lh3.googleusercontent.com/aida-public/AB6AXuDBTim8apXnQModREW6JUAlsQjaq_Xj5TxHn1QeSuwh-I3yDxlF5Ra-27DKzp71DPuKsxujHa5TakdjaKDmDuee656Qu5POzS1vx_9je45QmA5OXneXNBnAEXwcHVZ2vzEHSQfFoLUd2YD_2ow4xde2ylqsVhNBQpFdu01vnGCHDI4kCTRYgmFXgOyfGYtMXzz50V88YZL_LiPJoMl7yOoUaKZqX0XuN2FVXEqovxZEiyl8by7uoZULqg')\"></div>\n<div class=\"absolute inset-0 bg-black/20 group-hover:bg-black/10 transition-colors\"></div>\n<div class=\"absolute bottom-md left-md\">\n<div class=\"bg-surface-catalog/90 backdrop-blur-sm px-md py-xs rounded-lg\">\n<h3 class=\"font-headline-sm text-headline-sm text-on-background\">Accesorios</h3>\n</div>\n</div>\n</div>\n<div class=\"flex-1 group cursor-pointer relative overflow-hidden rounded-[24px] bg-surface-container-low flex items-center justify-center border border-outline-variant/20 hover:border-primary/50 transition-colors\">\n<div class=\"text-center p-md\">\n<span class=\"material-symbols-outlined text-[48px] text-primary mb-sm block\" data-icon=\"auto_awesome\">auto_awesome</span>\n<h3 class=\"font-headline-sm text-headline-sm text-primary mb-xs\">Recomendaciones</h3>\n<p class=\"font-body-sm text-body-sm text-on-surface-variant\">Basadas en tu estilo</p>\n</div>\n</div>\n</div>\n</section>\n<!-- New Arrivals Carousel -->\n<section class=\"py-xl\">\n<div class=\"flex justify-between items-end mb-lg\">\n<h2 class=\"font-headline-md text-headline-md text-primary\">Novedades</h2>\n<a class=\"font-util-mono text-util-mono text-secondary hover:text-secondary-fixed-dim transition-colors hidden md:block\" href=\"#\">Ver todo</a>\n</div>\n<div class=\"flex overflow-x-auto gap-lg pb-md hide-scroll snap-x\">\n<!-- Product Card 1 -->\n<div class=\"min-w-[260px] md:min-w-[300px] flex-none snap-start bg-surface-catalog rounded-[16px] shadow-sm border border-outline-variant/10 p-md flex flex-col gap-sm hover:shadow-md transition-shadow group\">\n<div class=\"relative w-full aspect-square rounded-lg overflow-hidden bg-surface-container-low mb-sm\">\n<img class=\"w-full h-full object-cover transition-transform duration-500 group-hover:scale-105\" data-alt=\"A minimalist tech pouch in deep navy blue nylon, sitting on a pale ash wood desk top next to a ceramic coffee mug. Bright, airy, light-mode studio lighting highlights the texture of the fabric. Clean composition, modern tactile feel.\" src=\"https://lh3.googleusercontent.com/aida-public/AB6AXuDQdawuBGYtq5ewQoGpeuR5gJUuPmXvP8U0tI6EHSMfPmQgPE0PLGv5prq8C3lxhf4ZtfGfMh1CmBBNXWw7RpSqW-f5pkqyL_vdUh1x07Cw9MnkiKfbt5Iygt-9XaTL9Q26whgrXOaYIHTuLVxyvbZySqHUXkky0Lmd4Q-k820-l_If40pThpJwz43vK9ult8jqQQ19lr4AKLVUXpja1wjk5Og_N-P3SIraJa4rp0XpSjuFh6MHIKVIAg\">\n<div class=\"absolute top-sm right-sm bg-secondary-container text-on-secondary-container px-2 py-1 rounded text-xs font-util-mono-sm flex items-center gap-1\">\n<span class=\"material-symbols-outlined text-[14px]\" data-icon=\"check_circle\">check_circle</span> Disponible\n                        </div>\n</div>\n<div>\n<h4 class=\"font-body-lg text-body-lg text-on-background font-medium line-clamp-1\">Tech Pouch Minimal</h4>\n<p class=\"font-body-sm text-body-sm text-text-muted mb-xs\">Organizador de cables</p>\n<div class=\"flex justify-between items-center mt-sm\">\n<span class=\"font-headline-sm text-headline-sm text-primary\">$45.00</span>\n<button class=\"w-8 h-8 rounded-full bg-surface-container flex items-center justify-center text-on-surface-variant hover:bg-primary hover:text-on-primary transition-colors\">\n<span class=\"material-symbols-outlined text-[18px]\" data-icon=\"add\">add</span>\n</button>\n</div>\n</div>\n</div>\n<!-- Product Card 2 -->\n<div class=\"min-w-[260px] md:min-w-[300px] flex-none snap-start bg-surface-catalog rounded-[16px] shadow-sm border border-outline-variant/10 p-md flex flex-col gap-sm hover:shadow-md transition-shadow group\">\n<div class=\"relative w-full aspect-square rounded-lg overflow-hidden bg-surface-c